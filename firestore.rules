rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /elections/{electionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;

      match /candidates/{candidateId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if false;
      }
    }

    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.electionId is string
        && request.resource.data.candidateId is string
        && voteId == request.resource.data.electionId + "_" + request.auth.uid
        && !exists(/databases/$(database)/documents/votes/$(voteId));
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /votedElections/{electionId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
  }
}
